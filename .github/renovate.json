{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits",
    ":timezone(Europe/Berlin)"
  ],
  "enabledManagers": ["gradle", "github-actions"],
  "ignorePaths": ["**/build/**", "**/.gradle/**", "**/node_modules/**"],
  "schedule": ["before 6am on the first day of the month"],
  "prConcurrentLimit": 10,
  "prHourlyLimit": 0,
  "rangeStrategy": "pin",
  "configMigration": true,
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 6am on the first day of the month"]
  },
  "packageRules": [
    {
      "description": "Allow unstable (rc/alpha/beta/dev/milestone) versions by default.",
      "matchManagers": ["gradle", "github-actions"],
      "matchPackageNames": ["*"],
      "ignoreUnstable": false,
      "respectLatest": false
    },
    {
      "description": "Compose Multiplatform artifacts and plugin.",
      "groupName": "Compose Multiplatform",
      "matchPackageNames": [
        "org.jetbrains.compose",
        "org.jetbrains.compose.{/,}**",
        "org.jetbrains.compose.material3:material3"
      ]
    },
    {
      "description": "Kotlin compiler, MPP and Compose compiler plugin — stable releases only.",
      "groupName": "Kotlin",
      "matchPackageNames": [
        "org.jetbrains.kotlin.multiplatform",
        "org.jetbrains.kotlin.plugin.compose",
        "org.jetbrains.kotlin:**",
        "org.jetbrains.kotlin.{/,}**"
      ],
      "ignoreUnstable": true,
      "respectLatest": true
    },
    {
      "description": "kotlinx-datetime — stable releases only.",
      "groupName": "kotlinx-datetime",
      "matchPackageNames": ["org.jetbrains.kotlinx:kotlinx-datetime"],
      "ignoreUnstable": true,
      "respectLatest": true
    },
    {
      "description": "AndroidX Lifecycle (JetBrains MPP fork).",
      "groupName": "AndroidX Lifecycle",
      "matchPackageNames": ["org.jetbrains.androidx.lifecycle:**"]
    },
    {
      "description": "Haze blur library family.",
      "groupName": "Haze",
      "matchPackageNames": ["dev.chrisbanes.haze:**"]
    },
    {
      "description": "GitHub Actions workflow updates.",
      "groupName": "GitHub Actions",
      "matchManagers": ["github-actions"],
      "matchPackageNames": ["*"]
    }
  ]
}
